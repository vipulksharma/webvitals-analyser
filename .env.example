# MongoDB connection string (MongoDB Atlas recommended for Vercel)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/lighthouse-eagleeye?retryWrites=true&w=majority

# SMTP for alert emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_FROM=EagleEye Alerts <alerts@example.com>

# Optional: protect POST /api/alerts/run-check (required in production)
ALERT_CRON_SECRET=change-me-in-production
